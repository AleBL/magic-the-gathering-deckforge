{
  "name": "magic-the-gathering-deckforge",
  "version": "0.8.0",
  "license": "MIT",
  "main": "dist-electron/index.js",
  "author": {
    "name": "Alessandro Barros"
  },
  "description": "Magic: The Gathering card search, deck builder, active analytics, and playtest simulator.",
  "keywords": [
    "vite",
    "react",
    "electron",
    "typescript",
    "mtg",
    "deckforge"
  ],
  "repository": {
    "url": "https://github.com/AleBL/magic-the-gathering-deckforge"
  },
  "productName": "MTG Deck Forge",
  "packageManager": "yarn@4.17.1",
  "scripts": {
    "dev": "vite",
    "dev:web": "vite --config vite.config.web.ts",
    "build": "yarn build:vite && yarn build:electron",
    "build:vite": "vite build",
    "build:web": "vite build --config vite.config.web.ts",
    "build:electron": "tsc -p electron",
    "dist": "yarn clean && yarn build && electron-builder --publish never",
    "build:win": "yarn clean && yarn build && electron-builder --win --publish never",
    "build:mac": "yarn clean && yarn build && electron-builder --mac --publish never",
    "build:linux": "yarn clean && yarn build && electron-builder --linux --publish never",
    "pack": "yarn clean && yarn build && electron-builder --dir",
    "clean": "rimraf dist dist-electron dist-vite",
    "type-check": "tsc",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "lint": "eslint . --fix",
    "lint:check": "eslint .",
    "i18n:check": "node scripts/i18n-check.mjs --ci",
    "deps:update": "taze major -I"
  },
  "dependencies": {
    "@vitejs/plugin-react": "^4.5.2",
    "dexie": "^4.4.4",
    "dexie-react-hooks": "^4.4.0",
    "i18next": "^24.2.3",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "react-i18next": "^15.5.2",
    "react-icons": "^5.5.0",
    "recharts": "^3.8.1",
    "scryfall-sdk": "^4.2.0",
    "vite": "^6.3.5",
    "vite-plugin-electron": "^0.29.1",
    "vite-plugin-electron-renderer": "^0.14.7",
    "zustand": "^5.0.14"
  },
  "devDependencies": {
    "@eslint/js": "^9.28.0",
    "@tailwindcss/vite": "^4.3.0",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^22.15.21",
    "@types/react": "^19.2.15",
    "@types/react-dom": "^19.2.3",
    "@vitest/coverage-v8": "^4.1.10",
    "autoprefixer": "^10.5.0",
    "electron": "^42.2.0",
    "electron-builder": "^26.8.1",
    "eslint": "^9.28.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "eslint-plugin-prettier": "^5.5.5",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^5.2.0",
    "globals": "^16.2.0",
    "jsdom": "^29.1.1",
    "postcss": "^8.5.15",
    "prettier": "^3.8.3",
    "rimraf": "^6.1.3",
    "tailwindcss": "^4.3.0",
    "taze": "^19.13.0",
    "typescript": "^5.8.3",
    "typescript-eslint": "^8.59.4",
    "vite-plugin-pwa": "^1.3.0",
    "vitest": "^4.1.10"
  },
  "build": {
    "appId": "com.alessandro.mtgdeckforge",
    "productName": "MTG Deck Forge",
    "asar": true,
    "directories": {
      "output": "dist",
      "buildResources": "resources"
    },
    "files": [
      "dist-electron",
      "dist-vite"
    ],
    "win": {
      "icon": "resources/icon.png",
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        },
        {
          "target": "zip",
          "arch": [
            "x64"
          ]
        }
      ]
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": "always",
      "createStartMenuShortcut": true,
      "shortcutName": "MTG Deck Forge",
      "license": "LICENSE.md",
      "runAfterFinish": true
    },
    "mac": {
      "icon": "resources/icon.png",
      "category": "public.app-category.entertainment",
      "target": [
        "dmg",
        "zip"
      ]
    },
    "dmg": {
      "icon": "resources/icon.png",
      "window": {
        "width": 540,
        "height": 380
      },
      "contents": [
        {
          "x": 410,
          "y": 150,
          "type": "link",
          "path": "/Applications"
        },
        {
          "x": 130,
          "y": 150,
          "type": "file"
        }
      ]
    },
    "linux": {
      "icon": "resources/icon.png",
      "category": "Game",
      "maintainer": "Alessandro Barros",
      "target": [
        "AppImage",
        "deb",
        "zip"
      ]
    }
  }
}
