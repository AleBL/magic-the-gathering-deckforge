{
  "name": "magic-the-gathering-deckforge",
  "version": "0.1.0",
  "license": "MIT",
  "main": "dist-electron/index.js",
  "author": {
    "name": "Alessandro Barros"
  },
  "description": "Premium Magic: The Gathering card search, deck builder, active analytics, and playtest simulator.",
  "keywords": [
    "vite",
    "react",
    "electron",
    "typescript",
    "mtg",
    "deckforge"
  ],
  "repository": {
    "url": "https://github.com/AleBL/magic-the-gathering-deckforge"
  },
  "productName": "MTG Deck Forge",
  "scripts": {
    "dev": "vite",
    "dev:web": "vite --config vite.config.web.ts",
    "build": "npm run build:vite && npm run build:electron",
    "build:vite": "vite build",
    "build:electron": "tsc -p electron",
    "dist": "npm run build && electron-builder",
    "build:win": "npm run build && electron-builder --win",
    "build:mac": "npm run build && electron-builder --mac",
    "build:linux": "npm run build && electron-builder --linux",
    "pack": "npm run build && electron-builder --dir",
    "clean": "rimraf dist dist-electron dist-vite",
    "type-check": "tsc",
    "lint": "eslint . --fix",
    "deps:update": "taze major -I"
  },
  "dependencies": {
    "@vitejs/plugin-react": "^4.5.2",
    "i18next": "^24.2.3",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "react-i18next": "^15.5.2",
    "react-icons": "^5.5.0",
    "scryfall-sdk": "^4.2.0",
    "vite": "^6.3.5",
    "vite-plugin-electron": "^0.29.1",
    "vite-plugin-electron-renderer": "^0.14.7"
  },
  "devDependencies": {
    "@eslint/js": "^9.28.0",
    "@tailwindcss/vite": "^4.3.0",
    "@types/node": "^22.15.21",
    "@types/react": "^19.2.15",
    "@types/react-dom": "^19.2.3",
    "@typescript-eslint/eslint-plugin": "^8.59.4",
    "@typescript-eslint/parser": "^8.59.4",
    "autoprefixer": "^10.5.0",
    "concurrently": "^9.2.1",
    "electron": "^42.2.0",
    "electron-builder": "^26.8.1",
    "esbuild": "*",
    "eslint": "^9.28.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "eslint-plugin-prettier": "^5.5.5",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^5.2.0",
    "globals": "^16.2.0",
    "postcss": "^8.5.15",
    "prettier": "^3.8.3",
    "tailwindcss": "^4.3.0",
    "taze": "^19.13.0",
    "typescript": "^5.8.3",
    "typescript-eslint": "^8.59.4"
  },
  "build": {
    "appId": "com.alessandro.mtgdeckforge",
    "productName": "MTG Deck Forge",
    "asar": true,
    "directories": {
      "output": "dist",
      "buildResources": "resources"
    },
    "files": [
      "dist-electron",
      "dist-vite"
    ],
    "win": {
      "icon": "resources/icon.png",
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ]
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": "always",
      "createStartMenuShortcut": true,
      "shortcutName": "MTG Deck Forge",
      "license": "LICENSE.md",
      "installerIcon": "resources/icon.png",
      "uninstallerIcon": "resources/icon.png",
      "installerHeaderIcon": "resources/icon.png",
      "runAfterFinish": true
    },
    "mac": {
      "icon": "resources/icon.png",
      "category": "public.app-category.entertainment",
      "target": [
        "dmg"
      ]
    },
    "dmg": {
      "icon": "resources/icon.png",
      "window": {
        "width": 540,
        "height": 380
      },
      "contents": [
        {
          "x": 410,
          "y": 150,
          "type": "link",
          "path": "/Applications"
        },
        {
          "x": 130,
          "y": 150,
          "type": "file"
        }
      ]
    },
    "linux": {
      "icon": "resources/icon.png",
      "category": "Game",
      "target": [
        "AppImage",
        "deb"
      ]
    }
  }
}